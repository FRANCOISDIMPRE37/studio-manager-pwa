#!/bin/bash
# =============================================================================
# STUDIO MANAGER — Script de déploiement d'une nouvelle instance client
# Société Intemporelle — Usage interne uniquement
# =============================================================================
# Usage : ./nouveau-client.sh <slug> "<Nom du salon>"
# Exemple : ./nouveau-client.sh salon-dupont "Salon Dupont"
#
# Ce script :
#   1. Clone le dépôt GitHub dans /var/www/<slug>
#   2. Installe les dépendances et compile l'application
#   3. Configure Nginx avec un sous-domaine dédié
#   4. Génère un certificat SSL Let's Encrypt
#   5. Démarre le service avec PM2
# =============================================================================

set -e

# --- Paramètres ---
SLUG="${1}"
NOM_SALON="${2:-Studio Manager}"
DOMAIN_BASE="studio.intemporelle.eu"
REPO_URL="https://github.com/INTEMPORELLE/studio-manager-pwa.git"
APP_DIR="/var/www/${SLUG}"
PORT_BASE=4000  # Le port sera 4000 + numéro d'instance

# --- Validation ---
if [ -z "$SLUG" ]; then
  echo "❌ Usage : ./nouveau-client.sh <slug> \"<Nom du salon>\""
  echo "   Exemple : ./nouveau-client.sh salon-dupont \"Salon Dupont\""
  exit 1
fi

if [[ ! "$SLUG" =~ ^[a-z0-9-]+$ ]]; then
  echo "❌ Le slug ne doit contenir que des lettres minuscules, chiffres et tirets"
  exit 1
fi

DOMAIN="${SLUG}.${DOMAIN_BASE}"
echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║     STUDIO MANAGER — Nouveau client : ${SLUG}"
echo "║     Domaine : https://${DOMAIN}"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

# --- Calcul du port ---
INSTANCE_COUNT=$(ls /var/www/ 2>/dev/null | grep -c "^" || echo 0)
PORT=$((PORT_BASE + INSTANCE_COUNT))
echo "📡 Port assigné : ${PORT}"

# --- Vérification des prérequis ---
echo "🔍 Vérification des prérequis..."
command -v node >/dev/null 2>&1 || { echo "❌ Node.js requis. Installez-le avec : curl -fsSL https://deb.nodesource.com/setup_20.x | sudo bash - && sudo apt-get install -y nodejs"; exit 1; }
command -v pnpm >/dev/null 2>&1 || { echo "📦 Installation de pnpm..."; npm install -g pnpm; }
command -v pm2 >/dev/null 2>&1 || { echo "📦 Installation de PM2..."; npm install -g pm2; }
command -v nginx >/dev/null 2>&1 || { echo "❌ Nginx requis. Installez-le avec : sudo apt-get install -y nginx"; exit 1; }
echo "✅ Prérequis OK"

# --- Clone du dépôt ---
echo ""
echo "📥 Clonage du dépôt..."
if [ -d "$APP_DIR" ]; then
  echo "⚠️  Le dossier ${APP_DIR} existe déjà. Mise à jour..."
  cd "$APP_DIR" && git pull origin main
else
  git clone "$REPO_URL" "$APP_DIR"
  cd "$APP_DIR"
fi

# --- Installation des dépendances ---
echo ""
echo "📦 Installation des dépendances..."
pnpm install --frozen-lockfile

# --- Fichier .env ---
echo ""
echo "⚙️  Configuration de l'environnement..."
cat > "${APP_DIR}/.env" << EOF
NODE_ENV=production
PORT=${PORT}
DATABASE_URL=file:./data/${SLUG}.db
JWT_SECRET=$(openssl rand -hex 32)
VITE_APP_TITLE=Studio Manager — ${NOM_SALON}
EOF
echo "✅ .env créé"

# --- Création du dossier data ---
mkdir -p "${APP_DIR}/data"

# --- Build ---
echo ""
echo "🔨 Compilation de l'application..."
cd "$APP_DIR" && pnpm build
echo "✅ Build terminé"

# --- Configuration Nginx ---
echo ""
echo "🌐 Configuration Nginx pour ${DOMAIN}..."
cat > "/etc/nginx/sites-available/${SLUG}" << EOF
server {
    listen 80;
    server_name ${DOMAIN};

    location / {
        proxy_pass http://127.0.0.1:${PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_cache_bypass \$http_upgrade;
        proxy_read_timeout 86400;
    }
}
EOF

ln -sf "/etc/nginx/sites-available/${SLUG}" "/etc/nginx/sites-enabled/${SLUG}"
nginx -t && systemctl reload nginx
echo "✅ Nginx configuré"

# --- Certificat SSL ---
echo ""
echo "🔒 Génération du certificat SSL..."
if command -v certbot >/dev/null 2>&1; then
  certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "francois-dimpre@intemporelle.eu" || echo "⚠️  SSL échoué (DNS pas encore propagé ?). Relancez : certbot --nginx -d ${DOMAIN}"
else
  echo "⚠️  Certbot non installé. Installez-le : sudo apt-get install -y certbot python3-certbot-nginx"
  echo "   Puis : sudo certbot --nginx -d ${DOMAIN}"
fi

# --- Démarrage avec PM2 ---
echo ""
echo "🚀 Démarrage du service PM2..."
cd "$APP_DIR"
pm2 start dist/index.js --name "${SLUG}" --env production || pm2 restart "${SLUG}"
pm2 save
echo "✅ Service démarré : ${SLUG}"

# --- Résumé ---
echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║  ✅ INSTANCE CRÉÉE AVEC SUCCÈS"
echo "║"
echo "║  Salon    : ${NOM_SALON}"
echo "║  URL      : https://${DOMAIN}"
echo "║  Port     : ${PORT}"
echo "║  Dossier  : ${APP_DIR}"
echo "║"
echo "║  ⚠️  ÉTAPES MANUELLES RESTANTES :"
echo "║  1. Ajouter l'entrée DNS chez IONOS :"
echo "║     Type A  |  ${SLUG}.studio  |  $(curl -s ifconfig.me)"
echo "║  2. Attendre la propagation DNS (5-30 min)"
echo "║  3. Relancer SSL si nécessaire :"
echo "║     certbot --nginx -d ${DOMAIN}"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""
